#!/usr/bin/env python

import argparse
import sys
import os
from fq_manifestor import (fq_manifestor,
                           _default_fq_extensions,
                           _default_split_pattern,
                           _default_f_read_pattern,
                           _default_r_read_pattern,
                           _default_exclude_patterns)

def main():
    parser = argparse.ArgumentParser(
        description="Generate QIIME 2 paired-end fastq manifest files from a directory of fastq files",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )

    # Required arguments
    parser.add_argument('input_dir',
                        help='Directory containing fastq files')
    parser.add_argument('output_fp',
                        help='Output filepath for the manifest')

    # Optional arguments
    parser.add_argument('--fq-extensions',
                        type=str,
                        nargs='+',
                        default=_default_fq_extensions,
                        help='List of fastq file extensions to look for')

    parser.add_argument('--split-pattern',
                        type=str,
                        default=_default_split_pattern,
                        help='Pattern to split filename to extract sample ID')

    parser.add_argument('--f-read-pattern',
                        type=str,
                        default=_default_f_read_pattern,
                        help='Pattern to identify forward reads')

    parser.add_argument('--r-read-pattern',
                        type=str,
                        default=_default_r_read_pattern,
                        help='Pattern to identify reverse reads')

    parser.add_argument('--exclude-patterns',
                        type=str,
                        nargs='+',
                        default=_default_exclude_patterns,
                        help='List of patterns to exclude from filepaths')

    parser.add_argument('--quiet',
                        action='store_true',
                        help='Suppress verbose output')

    args = parser.parse_args()
    print(args.f_read_pattern)

    # Check if input directory exists
    if not os.path.isdir(args.input_dir):
        print(f"Error: Input directory '{args.input_dir}' does not exist or is not a directory.",
              file=sys.stderr)
        sys.exit(1)

    # Run the fq_manifestor function with provided arguments
    try:
        fq_manifestor(
            input_dir=args.input_dir,
            output_fp=args.output_fp,
            fq_extensions=args.fq_extensions,
            split_pattern=args.split_pattern,
            f_read_pattern=args.f_read_pattern,
            r_read_pattern=args.r_read_pattern,
            exclude_patterns=args.exclude_patterns,
            verbose=not args.quiet
        )
    except ValueError as e:
        print(f"Error: {str(e)}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Unexpected error: {str(e)}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()